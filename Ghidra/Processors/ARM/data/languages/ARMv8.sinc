	mult_addr = mult_addr + 1;
	*[register]:1 ptr1 = *:1 mult_addr;
	mult_addr = mult_addr + 1;
	count = count + 1;
	ptr0 = ptr0 + 1;
	ptr1 = ptr1 + 1;
	if count == 16 goto <loop_end>;
