# F5.1.221 p7651 STLEXD
:stlexd^COND Rd,Rm,Rm2,[Rn]           is TMode=0 & ARMcond=1 & COND & c2027=0x1a & Rn & Rd & c0411=0xe9 & Rm & Rm2 {
