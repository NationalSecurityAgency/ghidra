	local result:8 = zext(thv_RdaHi) << 32 | zext(thv_RdaLo);
	result = result >> amount;
	result = UnsignedSaturate(result,64:2);
	thv_RdaLo = result[0,32];
	thv_RdaHi = result[32,32];
}

