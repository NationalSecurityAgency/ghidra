	|   (TMode=1 & thv_c2831=0b1111 & thv_c2327=0b11110 & thv_c2021=0b01 & thv_c0811=0b1111 & thv_c0404=1 & thv_c0606=0))
	& Dd & Dn & Dm
	{ Dd = FPMaxNum(Dn, Dm); }

