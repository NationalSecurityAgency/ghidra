<?xml version="1.0" encoding="UTF-8"?>

<!--
    NDS32 processor spec for the MediaTek MT3616 Bluetooth core
    (used in the PS5 DualSense controller's "rom_joined.bin" firmware).

    Memory layout extracted from an existing Ghidra database of
    rom_joined.bin (the DualSense firmware).  The chip exposes the N9
    Andes core's ILM ROM/RAM together with two SRAM banks and an
    aliased CM4-coprocessor MMIO range.

      0x00000000 + 0x60000   ILM_ROM        on-chip ROM (rx)
      0x000d0000 + 0x50000   ILM_RAM        on-chip RAM (rw)
      0x00400000 + 0xd000    SYSRAM_N9      N9-visible system RAM
      0x02090000 + 0x80000   DLM_RAM        N9 data local memory
      0x20000000 + 0x80000   SYSRAM_M4      M4 coprocessor SRAM (alias)
      0x80000000-0x83090000  various        MMIO peripheral windows
      0xc0000000 + 0x8000    csr            NDS32 system register space
                                            (csreg overlay, language-defined)

    Everything else (default symbols, IFC_ON context) mirrors
    nds32.pspec.  Selected at import time via "variant=mt3616" /
    language id NDS32:LE:32:mt3616.
-->

<processor_spec>
  <properties>
    <property key="pcodeInjectLibraryClass" value="ghidra.app.util.pcodeInject.PcodeInjectLibraryNDS32"/>
    <property key="useropLibs" value="nds32"/>
  </properties>
  <programcounter register="pc"/>

  <context_data>
    <tracked_set space="ram">
      <set name="IFC_ON" val="0"/>
    </tracked_set>
  </context_data>

  <default_memory_blocks>
    <memory_block name="ILM_ROM"     start_address="ram:0x00000000" length="0x60000"  initialized="false"/>
    <memory_block name="ILM_RAM"     start_address="ram:0x000d0000" length="0x50000"  initialized="false"/>
    <memory_block name="SYSRAM_N9"   start_address="ram:0x00400000" length="0xd000"   initialized="false"/>
    <memory_block name="DLM_RAM"     start_address="ram:0x02090000" length="0x80000"  initialized="false"/>
    <memory_block name="SYSRAM_M4"   start_address="ram:0x20000000" length="0x80000"  initialized="false"/>

    <memory_block name="confg"       start_address="ram:0x80000000" length="0x10000"  initialized="false"/>
    <memory_block name="dma"         start_address="ram:0x80010000" length="0x10000"  initialized="false"/>
    <memory_block name="top_cfg_off" start_address="ram:0x80020000" length="0x10000"  initialized="false"/>

    <memory_block name="btsys"       start_address="ram:0x81000000" length="0x10000"  initialized="false"/>
    <memory_block name="top_cfg_aon" start_address="ram:0x81020000" length="0x10000"  initialized="false"/>
    <memory_block name="cirq"        start_address="ram:0x81040000" length="0x10000"  initialized="false"/>
    <memory_block name="gpt"         start_address="ram:0x81050000" length="0x8000"   initialized="false"/>
    <memory_block name="pta"         start_address="ram:0x81060000" length="0x10000"  initialized="false"/>
    <memory_block name="efuse"       start_address="ram:0x81070000" length="0x10000"  initialized="false"/>
    <memory_block name="wdt"         start_address="ram:0x81080000" length="0x10000"  initialized="false"/>

    <memory_block name="confg_cm4"   start_address="ram:0x83000000" length="0x10000"  initialized="false"/>
    <memory_block name="dma_cm4"     start_address="ram:0x83010000" length="0x10000"  initialized="false"/>
    <memory_block name="gpt_cm4"     start_address="ram:0x83050000" length="0x10000"  initialized="false"/>
    <memory_block name="wdt_cm4"     start_address="ram:0x83080000" length="0x10000"  initialized="false"/>

    <memory_block name="csr"         start_address="csreg:0x0"      length="0x8000"   initialized="false"/>
  </default_memory_blocks>

  <default_symbols>
       <symbol name="cpu_ver"         address="csreg:0x000"     size="4" description="" />
       <symbol name="core_id"         address="csreg:0x001"     size="4" description="" />
       <symbol  name="icm_cfg"        address="csreg:0x008"     size="4" description="" />
       <symbol  name="dcm_cfg"        address="csreg:0x010"     size="4" description="" />
       <symbol  name="mmu_cfg"        address="csreg:0x018"     size="4" description="" />
       <symbol  name="msc_cfg"        address="csreg:0x020"     size="4" description="" />
       <symbol  name="msc_cfg2"       address="csreg:0x021"     size="4" description="" />
       <symbol  name="fucop_exist"    address="csreg:0x028"     size="4" description="" />

       <symbol name="psw"             address="csreg:0x080"     size="4" description="" />
       <symbol name="ipsw"            address="csreg:0x081"     size="4" description="" />
       <symbol name="p_ipsw"          address="csreg:0x082"     size="4" description="" />
       <symbol name="ivb"             address="csreg:0x089"     size="4" description="" />
       <symbol name="int_ctrl"        address="csreg:0x08a"     size="4" description="" />
       <symbol name="int_gpr_push_dis"  address="csreg:0x08b"   size="4" description="" />
       <symbol name="eva"            address="csreg:0x091"      size="4" description="" />
       <symbol name="p_eva"          address="csreg:0x092"      size="4" description="" />
       <symbol name="itype"          address="csreg:0x099"      size="4" description="" />
       <symbol name="p_itype"        address="csreg:0x09a"      size="4" description="" />
       <symbol name="merr"           address="csreg:0x0a1"      size="4" description="" />
       <symbol name="ipc"            address="csreg:0x0a9"      size="4" description="" />
       <symbol name="p_ipc"          address="csreg:0x0aa"      size="4" description="" />
       <symbol name="oipc"           address="csreg:0x0ab"      size="4" description="" />
       <symbol name="p_p0"           address="csreg:0x0b2"      size="4" description="" />
       <symbol name="p_p1"           address="csreg:0x0ba"      size="4" description="" />
       <symbol name="int_mask"       address="csreg:0x0c0"      size="4" description="" />
       <symbol name="int_mask2"      address="csreg:0x0c1"      size="4" description="" />
       <symbol name="int_mask3"      address="csreg:0x0c2"      size="4" description="" />
       <symbol name="int_pend"       address="csreg:0x0c8"      size="4" description="" />
       <symbol name="int_pend2"      address="csreg:0x0c9"      size="4" description="" />
       <symbol name="int_pend3"      address="csreg:0x0ca"      size="4" description="" />
       <symbol name="int_trigger"    address="csreg:0x0cc"      size="4" description="" />
       <symbol name="int_trigger2"   address="csreg:0x0cd"      size="4" description="" />
       <symbol name="sp_usr"         address="csreg:0x0d0"      size="4" description="" />
       <symbol name="sp_priv"        address="next"             size="4" description="" />
       <symbol name="sp_usr1"        address="next"             size="4" description="" />
       <symbol name="sp_priv1"       address="next"             size="4" description="" />
       <symbol name="sp_usr2"        address="next"             size="4" description="" />
       <symbol name="sp_priv2"       address="next"             size="4" description="" />
