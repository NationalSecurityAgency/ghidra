       <symbol name="bpa1"           address="next"             size="4" description="" />
       <symbol name="bpa2"           address="next"             size="4" description="" />
       <symbol name="bpa3"           address="next"             size="4" description="" />
       <symbol name="bpa4"           address="next"             size="4" description="" />
