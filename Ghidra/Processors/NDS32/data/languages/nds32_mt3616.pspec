       <symbol name="bpc1"           address="next"             size="4" description="" />
       <symbol name="bpc2"           address="next"             size="4" description="" />
       <symbol name="bpc3"           address="next"             size="4" description="" />
       <symbol name="bpc4"           address="next"             size="4" description="" />
