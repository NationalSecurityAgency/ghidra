# u6

u6ext: imm is u6_imm [ imm = u6_imm | (u6_ext << 6); ] { export *[const]:4 imm; }

define pcodeop kentsp;
define pcodeop setsr;
define pcodeop getsr;
define pcodeop kcalli;
define pcodeop clrsr;


@define PRE ""
@define POST ""
@include "u6_ops.sinc"

# We can't just use a u6 subtable and build directives for this, because it will prefer ru6 to u6 and fail to find a match
@define PRE "ru6_op=0b111100 & u10_imm; "
@define POST "[u6_ext = u10_imm;]"
@include "u6_ops.sinc"

# lu6 only
define pcodeop krestsp;
:krestsp imm is u6_op=0b111100 ; u6_op=0b0111101111 & u6_imm [ imm = u6_imm | (u6_ext << 6); ] {
	krestsp(imm:4);
}

# Some ops in r2r and 3r overlap, e.g. setd and add. Differentiate via the +27 on the encoded registers of the r2r format
# This also applies to ops in rus and 2rus e.g. mkmski and shli
# shr and eef (3r/2r)
@define IS_R2R_FMT "r2_op2_tmp >= 27"

# rus
define pcodeop chkcti;
:chkcti r2_op1, r2_op2c is rus_op0=0b11001 & rus_op1=1 & r2_op1 & r2_op2c & $(IS_R2R_FMT) {
	chkcti(r2_op1, r2_op2c);
}

define pcodeop getr;
:getr r2_op1, r2_op2c is rus_op0=0b10000 & rus_op1=0 & r2_op1 & r2_op2c & $(IS_R2R_FMT) {
	r2_op1 = getr(r2_op2c:4);
}

:mkmski r2_op1, r2_op2c_bitp is rus_op0=0b10100 & rus_op1=1 & r2_op1 & r2_op2c_bitp & $(IS_R2R_FMT) { 
	local msk:$(BPW) = (1 << r2_op2c_bitp)-1;
	r2_op1 = msk;
}

define pcodeop outcti;
:outcti r2_op1, r2_op2c is rus_op0=0b01001 & rus_op1=1 & r2_op1 & r2_op2c & $(IS_R2R_FMT) {
	outcti(r2_op1, r2_op2c:4);
}

:sexti r2_op1, r2_op2c_bitp is rus_op0=0b00110 & rus_op1=1 & r2_op1 & r2_op2c_bitp & $(IS_R2R_FMT) {
	local shf:4 = (32 - r2_op2c_bitp);
	local tmp:4 = r2_op1 << shf;
	r2_op1 = tmp s>> shf;
}

:zexti r2_op1, r2_op2c_bitp is rus_op0=0b01000 & rus_op1=1 & r2_op1 & r2_op2c_bitp & $(IS_R2R_FMT) {
	local shf:4 = (32 - r2_op2c_bitp);
	local tmp:4 = r2_op1 << shf;
	r2_op1 = tmp >> shf;
}


# r2r
define pcodeop out;
:out r2_op1, r2_op2 is rus_op0=0b10101 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	out(r2_op1, r2_op2);
}

define pcodeop outshr;
:outshr r2_op1, r2_op2 is rus_op0=0b10101 & rus_op1=1 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	outshr(r2_op1, r2_op2);
}

define pcodeop outt;
:outt r2_op1, r2_op2 is rus_op0=0b00001 & rus_op1=1 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	outt(r2_op1, r2_op2);
}

define pcodeop setd;
:setd r2_op1, r2_op2 is rus_op0=0b00010 & rus_op1=1 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	setd(r2_op1, r2_op2);
}

define pcodeop setpsc;
:setpsc r2_op1, r2_op2 is rus_op0=0b11000 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	setpsc(r2_op1, r2_op2);
}

define pcodeop setpt;
:setpt r2_op1, r2_op2 is rus_op0=0b00111 & rus_op1=1 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	setpt(r2_op1, r2_op2);
}

# 2r

:andnot r2_op1, r2_op2 is rus_op0=0b00101 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	r2_op1 = r2_op1 & ~(r2_op2);
}

define pcodeop bitrev;
:bitrev r2_op1, r2_op2 is rus_op0=0b00010 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	r2_op1 = bitrev(r2_op2);
}

define pcodeop byterev;
:byterev r2_op1, r2_op2 is rus_op0=0b00000 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	r2_op1 = byterev(r2_op2);
}

define pcodeop chkct;
:chkct r2_op1, r2_op2 is rus_op0=0b11001 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	chkct(r2_op1, r2_op2);
}

:clz r2_op1, r2_op2 is rus_op0=0b00001 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	r2_op1 = lzcount(r2_op2);
}

define pcodeop eef;
:eef r2_op1, r2_op2 is rus_op0=0b00101 & rus_op1=1 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	r2_op1 = eef(r2_op2);
}

define pcodeop eet;
:eet r2_op1, r2_op2 is rus_op0=0b00100 & rus_op1=1 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	r2_op1 = eet(r2_op2);
}

define pcodeop endin;
:endin r2_op1, r2_op2 is rus_op0=0b10010 & rus_op1=1 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	r2_op1 = endin(r2_op2);
}

define pcodeop getst;
:getst r2_op1, r2_op2 is rus_op0=0b00000 & rus_op1=1 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	r2_op1 = getst(r2_op2);
}

define pcodeop getts;
:getts r2_op1, r2_op2 is rus_op0=0b00111 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	r2_op1 = getts(r2_op2);
}

define pcodeop in;
:in r2_op1, r2_op2 is rus_op0=0b10110 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	r2_op1 = in(r2_op2);
}

define pcodeop inct;
:inct r2_op1, r2_op2 is rus_op0=0b10000 & rus_op1=1 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	r2_op1 = inct(r2_op2);
}

define pcodeop inshr;
:inshr r2_op1, r2_op2 is rus_op0=0b10110 & rus_op1=1 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	inshr(r2_op1, r2_op2);
}

define pcodeop int;
:int r2_op1, r2_op2 is rus_op0=0b10001 & rus_op1=1 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	int(r2_op1, r2_op2);
}

:mkmsk r2_op1, r2_op2 is rus_op0=0b10100 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	local msk:4 = (1 << r2_op2)-1;
	r2_op1 = msk;
}
:neg r2_op1, r2_op2 is rus_op0=0b10010 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	r2_op1 = -r2_op2;
}

:not r2_op1, r2_op2 is rus_op0=0b10001 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	r2_op1 = ~r2_op2;
}

define pcodeop outct;
:outct r2_op1, r2_op2 is rus_op0=0b01001 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	outct(r2_op1, r2_op2);
}

define pcodeop peek;
:peek r2_op1, r2_op2 is rus_op0=0b10111 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	r2_op1 = peek(r2_op2);
}
:"sext" r2_op1, r2_op2 is rus_op0=0b00110 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	local shf:4 = (32 - r2_op2);
	local tmp:4 = r2_op1 << shf;
	r2_op1 = tmp s>> shf;
}

define pcodeop testct;
:testct r2_op1, r2_op2 is rus_op0=0b10111 & rus_op1=1 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	r2_op1 = testct(r2_op2);
}

define pcodeop testwct;
:testwct r2_op1, r2_op2 is rus_op0=0b11000 & rus_op1=1 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	r2_op1 = testwct(r2_op2);
}
:"zext" r2_op1, r2_op2 is rus_op0=0b01000 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	local shf:4 = (32 - r2_op2);
	local tmp:4 = r2_op1 << shf;
	r2_op1 = tmp >> shf;
}

# l0r
define pcodeop dentsp;
# XS2 encoding
:dentsp is op0_15=0b1111111111101100 ; op0_15=0b0001011111101100 {
	dentsp();
}
# XS1 encoding
:dentsp is op0_15=0b0001011111101100 {
	dentsp();
}

define pcodeop drestsp;
# XS2 encoding
:drestsp is op0_15=0b1111111111101100 ; op0_15=0b0001111111101100 {
	drestsp();
}
# XS1 encoding
:drestsp is op0_15=0b0001011111101101 {
	drestsp();
}

define pcodeop dret;
# XS2 encoding
:dret is op0_15=0b1111111111101100 ; op0_15=0b0000111111101100 {
	dret();
}
# XS1 encoding
:dret is op0_15=0b0000011111111110 {
	dret();
}


# XS2 encoding
define pcodeop kret;
:kret is op0_15=0b1111111111101100 ; op0_15=0b0000011111101100 {
	kret();
}
# XS1 encoding
:kret is op0_15=0b0000011111111101 {
	kret();
}

# l2r

define pcodeop getd;
:getd r2_op1, r2_op2 is rus_op0=0b11111 & rus_op1=1 & r2_op1 & r2_op2 & $(IS_R2R_FMT) ; op0_15=0b0001111111101100 {
	r2_op1 = getd(r2_op2);
}

define pcodeop getn;
:getn r2_op1, r2_op2 is rus_op0=0b11111 & rus_op1=1 & r2_op1 & r2_op2 & $(IS_R2R_FMT) ; op0_15=0b0011011111101100 {
	r2_op1 = getn(r2_op2);
}

define pcodeop getps;
:getps r2_op1, r2_op2 is rus_op0=0b11111 & rus_op1=1 & r2_op1 & r2_op2 & $(IS_R2R_FMT) ; op0_15=0b0001011111101100 {
	r2_op1 = getps(r2_op2);
}

define pcodeop setc;
:setc r2_op1, r2_op2 is rus_op0=0b11111 & rus_op1=1 & r2_op1 & r2_op2 & $(IS_R2R_FMT) ; op0_15=0b0010111111101100 {
	setc(r2_op1, r2_op2);
}

define pcodeop testlcl;
:testlcl is rus_op0=0b11111 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) ; op0_15=0b0010011111101100 {
	r2_op1 = testlcl(r2_op2);
}

define pcodeop tinitcp;
:tinitcp r2_op1, r2_op2 is rus_op0=0b11111 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) ; op0_15=0b0000011111101101 {
	tinitcp(r2_op1, r2_op2);
}

define pcodeop tinitdp;
:tinitdp r2_op1, r2_op2 is rus_op0=0b11111 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) ; op0_15=0b0000111111101100 {
	tinitdp(r2_op1, r2_op2);
}

define pcodeop tinitlr;
:tinitlr r2_op1, r2_op2 is rus_op0=0b11111 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) ; op0_15=0b0001011111101100 {
	tinitlr(r2_op1, r2_op2);
}

define pcodeop tinitpc;
:tinitpc r2_op1, r2_op2 is rus_op0=0b11111 & rus_op1=1 & r2_op1 & r2_op2 & $(IS_R2R_FMT) ; op0_15=0b0000011111101100 {
	tinitpc(r2_op1, r2_op2);
}

define pcodeop tinitsp;
:tinitsp r2_op1, r2_op2 is rus_op0=0b11111 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) ; op0_15=0b0000011111101100 {
	tinitsp(r2_op1, r2_op2);
}

define pcodeop tsetmr;
:tsetmr r2_op1, r2_op2 is rus_op0=0b11111 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) ; op0_15=0b0000111111101101 {
	tsetmr(r2_op1, r2_op2);
}


# lr2r
define pcodeop setclk;
:setclk r2_op1, r2_op2 is rus_op0=0b11111 & rus_op1=1 & r2_op1 & r2_op2 & $(IS_R2R_FMT) ; op0_15=0b0000111111101100 {
	setclk(r2_op1, r2_op2);
}


define pcodeop setn;
:setn r2_op1, r2_op2 is rus_op0=0b11111 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) ; op0_15=0b0011011111101100 {
	setn(r2_op1, r2_op2);
}

define pcodeop setps;
:setps r2_op1, r2_op2 is rus_op0=0b11111 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) ; op0_15=0b0001111111101100 {
	setps(r2_op1, r2_op2);
}

define pcodeop setrdy;
:setrdy r2_op1, r2_op2 is rus_op0=0b11111 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) ; op0_15=0b0010111111101100 {
	setrdy(r2_op1, r2_op2);
}

define pcodeop settw;
:settw r2_op1, r2_op2 is rus_op0=0b11111 & rus_op1=1 & r2_op1 & r2_op2 & $(IS_R2R_FMT) ; op0_15=0b0010011111101100 {
	settw(r2_op1, r2_op2);
}

# l4r
define pcodeop crc8;
:crc8 rus2_op1r, l4r_op4, rus2_op2r, r3_op3r is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; l4r_op=0b000001111110 & l4r_op4 {
	local tmp:4 = crc8(rus2_op1r, l4r_op4, rus2_op2r, r3_op3r);
	rus2_op1r = tmp;
	l4r_op4 = tmp;
}

define pcodeop crcn;
:crcn rus2_op1r, l4r_op4, rus2_op2r, r3_op3r is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; l4r_op=0b000011111111 & l4r_op4 {
	local tmp:4 = crcn(rus2_op1r, l4r_op4, rus2_op2r, r3_op3r);
	rus2_op1r = tmp;
	l4r_op4 = tmp;
}

:ldd rus2_op1r, l4r_op4, rus2_op2r, r3_op3r is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; l4r_op=0b001001111110 & l4r_op4 {
	local ea:4 = rus2_op2r + r3_op3r*$(BPW)*2;
	rus2_op1r = *[ram]:4 ea;
	local ea2:4 = rus2_op2r + r3_op3r*$(BPW)*2 + $(BPW);
	l4r_op4 = *[ram]:4 ea2;
}
:maccs rus2_op1r, l4r_op4, rus2_op2r, r3_op3r is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; l4r_op=0b000011111110 & l4r_op4 {
	local tmp:8 = (zext(rus2_op1r) << 32) | zext(l4r_op4);
	local res:8 = tmp + sext(rus2_op2r) * sext(r3_op3r);
	rus2_op1r = res:4;
	l4r_op4 = res(4);
}
:maccu rus2_op1r, l4r_op4, rus2_op2r, r3_op3r is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; l4r_op=0b000001111111 & l4r_op4 {
	local tmp:8 = (zext(rus2_op1r) << 32) | zext(l4r_op4);
	local res:8 = tmp + zext(rus2_op2r) * zext(r3_op3r);
	rus2_op1r = res:4;
	l4r_op4 = res(4);
}
:std rus2_op1r, l4r_op4, rus2_op2r, r3_op3r is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; l4r_op=0b000101111110 & l4r_op4 {
	local ea:4 = rus2_op2r + r3_op3r*$(BPW)*2;
	*[ram]:$(BPW) ea = rus2_op1r;
	ea = ea + $(BPW);
	*[ram]:$(BPW) ea = rus2_op2r;
}


# l3rus
:lddi rus2_op1r, l4r_op4, rus2_op2r, rus2_op3i is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & rus2_op3i ; l4r_op=0b001001111111 & l4r_op4 {
	local ea:4 = rus2_op2r + rus2_op3i*$(BPW)*2;
	rus2_op1r = *[ram]:$(BPW) ea;
	ea = ea + $(BPW);
	rus2_op2r = *[ram]:$(BPW) ea;
}
:stdi rus2_op1r, l4r_op4, rus2_op2r, rus2_op3i is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & rus2_op3i ; l4r_op=0b000101111111 & l4r_op4 {
	local ea:4 = rus2_op2r + rus2_op3i*$(BPW)*2;
	*[ram]:$(BPW) ea = rus2_op1r;
	ea = ea + $(BPW);
	*[ram]:$(BPW) ea = rus2_op2r;
}

l5r_op5: r3_op3l is r3_op3l & r2_op2_tmp=0b11011 & r2_op2_tmp1=0 { export r3_op3l; }
l5r_op5: r3_op3l is r3_op3l & r2_op2_tmp=0b11110 & r2_op2_tmp1=0 { export r3_op3l; }
l5r_op5: r3_op3l is r3_op3l & r2_op2_tmp=0b11100 & r2_op2_tmp1=1 { export r3_op3l; }
l5r_op5: r3_op3m is r3_op3m & r2_op2_tmp=0b11100 & r2_op2_tmp1=0 { export r3_op3m; }
l5r_op5: r3_op3m is r3_op3m & r2_op2_tmp=0b11111 & r2_op2_tmp1=0 { export r3_op3m; }
l5r_op5: r3_op3m is r3_op3m & r2_op2_tmp=0b11101 & r2_op2_tmp1=1 { export r3_op3m; }
l5r_op5: r3_op3h is r3_op3h & r2_op2_tmp=0b11101 & r2_op2_tmp1=0 { export r3_op3h; }
l5r_op5: r3_op3h is r3_op3h & r2_op2_tmp=0b11011 & r2_op2_tmp1=1 { export r3_op3h; }
l5r_op5: r3_op3h is r3_op3h & r2_op2_tmp=0b11110 & r2_op2_tmp1=1 { export r3_op3h; }

l5r_op4: r3_op3l is r3_op3l & r2_op2_tmp=0b11011 & r2_op2_tmp1=0 { export r3_op3l; }
l5r_op4: r3_op3m is r3_op3m & r2_op2_tmp=0b11100 & r2_op2_tmp1=0 { export r3_op3m; }
l5r_op4: r3_op3h is r3_op3h & r2_op2_tmp=0b11101 & r2_op2_tmp1=0 { export r3_op3h; }
l5r_op4: r3_op3l is r3_op3l & r2_op2_tmp=0b11110 & r2_op2_tmp1=0 { export r3_op3l; }
l5r_op4: r3_op3m is r3_op3m & r2_op2_tmp=0b11111 & r2_op2_tmp1=0 { export r3_op3m; }
l5r_op4: r3_op3h is r3_op3h & r2_op2_tmp=0b11011 & r2_op2_tmp1=1 { export r3_op3h; }
l5r_op4: r3_op3l is r3_op3l & r2_op2_tmp=0b11100 & r2_op2_tmp1=1 { export r3_op3l; }
l5r_op4: r3_op3m is r3_op3m & r2_op2_tmp=0b11101 & r2_op2_tmp1=1 { export r3_op3m; }
l5r_op4: r3_op3h is r3_op3h & r2_op2_tmp=0b11110 & r2_op2_tmp1=1 { export r3_op3h; }

# l4rus

define pcodeop crc32_inc;
:crc32_inc rus2_op1r, l5r_op4, rus2_op2r, r3_op3r, r2_op2c_bitp is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; rus2_op=0b00101 & r1_op2=1 & l5r_op4 & r2_op2c_bitp & $(IS_R2R_FMT) {
	crc32_inc(rus2_op1r, l5r_op4, rus2_op2r, r3_op3r, r2_op2c_bitp:4);
}

define pcodeop lextract;
:lextract rus2_op1r, l5r_op4, rus2_op2r, r3_op3r, r2_op2c_bitp is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; rus2_op=0b00011 & r1_op2=0 & l5r_op4 & r2_op2c_bitp & $(IS_R2R_FMT) {
	rus2_op1r = lextract(rus2_op1r, l5r_op4, rus2_op2r, r3_op3r, r2_op2c_bitp:4);
}

define pcodeop linsert;
:linsert rus2_op1r, l5r_op4, rus2_op2r, r3_op3r, r2_op2c_bitp is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; rus2_op=0b00011 & r1_op2=1 & l5r_op4 & r2_op2c_bitp & $(IS_R2R_FMT) {
	rus2_op1r = linsert(rus2_op1r, l5r_op4, rus2_op2r, r3_op3r, r2_op2c_bitp:4);
}

# l5r


:ladd rus2_op1r, l5r_op4, rus2_op2r, r3_op3r, l5r_op5 is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; rus2_op=0b00000 & r1_op2=1 & l5r_op4 & l5r_op5 & $(IS_R2R_FMT) {
	local tmp:8 = zext(rus2_op2r) + zext(r3_op3r) + zext(l5r_op5&1);
	rus2_op1r = tmp:4;
	l5r_op4 = zext(tmp > zext(rus2_op1r));
}
:ldivu rus2_op1r, l5r_op4, rus2_op2r, r3_op3r, l5r_op5 is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; rus2_op=0b00000 & r1_op2=0 & l5r_op4 & l5r_op5 & $(IS_R2R_FMT) {
	local tmp:8 = zext(l5r_op5 << 32) | zext(rus2_op2r);
	local res:8 = tmp / zext(r3_op3r);
	local res2:8 = tmp % zext(r3_op3r); 
	rus2_op1r = res:4;
	l5r_op4 = res2:4;
}
:lsub rus2_op1r, l5r_op4, rus2_op2r, r3_op3r, l5r_op5 is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; rus2_op=0b00001 & r1_op2=0 & l5r_op4 & l5r_op5 & $(IS_R2R_FMT) {
	local tmp:8 = zext(rus2_op2r) - zext(r3_op3r) - zext(l5r_op5&1);
	rus2_op1r = tmp:4;
	l5r_op4 = zext(tmp > zext(rus2_op1r));
}
:xor4 rus2_op1r, l5r_op4, rus2_op2r, r3_op3r, l5r_op5 is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; rus2_op=0b00001 & r1_op2=1 & l5r_op4 & l5r_op5 & $(IS_R2R_FMT) {
	rus2_op1r = rus2_op2r ^ r3_op3r ^ l5r_op4 ^ l5r_op5;
}




:lmul rus2_op1r, l6r_op4r, rus2_op2r, r3_op3r, l6r_op5r, l6r_op6r is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; rus2_op=0b00000 & split_packed2 & l6r_op4r & l6r_op5r & l6r_op6r {
	local tmp:8 = zext(rus2_op2r) * zext(r3_op3r) + zext(l6r_op5r) + zext(l6r_op6r);
	l6r_op4r = tmp:4;
	rus2_op1r = tmp(4);
}

@include "xs3.sinc"

