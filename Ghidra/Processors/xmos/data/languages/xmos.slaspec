r2_op2c_bitp: 7 is imm0_1=0b11 & r2_op2_tmp=0b11110 & r2_op2_tmp1=0 { local tmp:4 = 7; export *[const]:4 tmp; }
r2_op2c_bitp: 7 is imm0_1=0b11 & r2_op2_tmp=0b11111 & r2_op2_tmp1=0 { local tmp:4 = 7; export *[const]:4 tmp; }
r2_op2c_bitp: 7 is imm0_1=0b11 & r2_op2_tmp=0b11011 & r2_op2_tmp1=1 { local tmp:4 = 7; export *[const]:4 tmp; }
r2_op2c_bitp: 8 is imm0_1=0b0 & r2_op2_tmp=0b11100 & r2_op2_tmp1=1 { local tmp:4 = 8; export *[const]:4 tmp; }
