# 1r
:bau r1_r is r1_op0=0b00100 & r1_op1=0b111111 & r1_op2=1 & r1_r {
	goto [r1_r];
}
:bla r1_r is r1_op0=0b00100 & r1_op1=0b111111 & r1_op2=0 & r1_r {
	lr = inst_next;
	goto [r1_r];
}
:bru r1_r is r1_op0=0b00101 & r1_op1=0b111111 & r1_op2=0 & r1_r {
	lr = inst_next;
	local dest:4 = inst_next + r1_r*$(IW);
	goto [dest];
}

define pcodeop clear_port_time;
:clrpt r1_r is r1_op0=0b10000 & r1_op1=0b111111 & r1_op2=0 & r1_r {
	clear_port_time(r1_r);
}

define pcodeop get_thread_reg;
:dgetreg r1_r is r1_op0=0b00111 & r1_op1=0b111111 & r1_op2=0 & r1_r {
	r1_r = get_thread_reg();
}

define pcodeop exception;
:ecallf r1_r is r1_op0=0b01001 & r1_op1=0b111111 & r1_op2=0 & r1_r {
	if(r1_r != 0) goto inst_next;
	exception();
}

:ecallt r1_r is r1_op0=0b01001 & r1_op1=0b111111 & r1_op2=1 & r1_r {
	if(r1_r == 0) goto inst_next;
	exception();
}

define pcodeop edu;
:edu r1_r is r1_op0=0b00000 & r1_op1=0b111111 & r1_op2=0 & r1_r {
