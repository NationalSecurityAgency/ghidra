# l5r
define pcodeop fmake;
:fmake rus2_op1r, l5r_op4, rus2_op2r, r3_op3r, l5r_op5 is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; rus2_op=0b00010 & r1_op2=0 & l5r_op4 & l5r_op5 & $(IS_R2R_FMT) {
	rus2_op1r = fmake(l5r_op4, rus2_op2r, r3_op3r, l5r_op5);
}

