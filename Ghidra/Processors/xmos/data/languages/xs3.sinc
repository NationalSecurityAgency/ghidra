# l3r

define pcodeop dvld;
:dvld rus2_op1r, rus2_op2r, r3_op3r is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; op0_15=0b1010111111101110 {
	dvld(rus2_op1r, rus2_op2r, r3_op3r);
}

define pcodeop dvst;
:dvst rus2_op1r, rus2_op2r, r3_op3r is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; op0_15=0b1010111111101101 {
	dvst(rus2_op1r, rus2_op2r, r3_op3r);
}

:fadd rus2_op1r, rus2_op2r, r3_op3r is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; op0_15=0b1011011111101110 {
	rus2_op1r = rus2_op2r f+ r3_op3r;
}

:feq rus2_op1r, rus2_op2r, r3_op3r is  rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; op0_15=0b1100011111101110 {
	rus2_op1r = zext(rus2_op2r f== r3_op3r);
}

:fgt rus2_op1r, rus2_op2r, r3_op3r is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; op0_15=0b1011111111101110 {
	rus2_op1r = zext(rus2_op2r f> r3_op3r);
}

:flt rus2_op1r, rus2_op2r, r3_op3r is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; op0_15=0b1011111111101111 {
	rus2_op1r = zext(rus2_op2r f< r3_op3r);
}

:fmul rus2_op1r, rus2_op2r, r3_op3r is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; op0_15=0b1011011111101101 {
	rus2_op1r = rus2_op2r f* r3_op3r;
}

define pcodeop fsexp;
:fsexp rus2_op1r, rus2_op2r, r3_op3r is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; op0_15=0b1011111111101101 {
	rus2_op1r = fsexp(rus2_op2r, r3_op3r);
}

:fsub rus2_op1r, rus2_op2r, r3_op3r is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; op0_15=0b1011011111101111 {
	rus2_op1r = rus2_op2r f- r3_op3r;
}

define pcodeop fun;
:fun rus2_op1r, rus2_op2r, r3_op3r is rus2_op=0b11111 & split_packed & rus2_op1r & rus2_op2r & r3_op3r ; op0_15=0b1100011111101101 {
	rus2_op1r = fun(rus2_op2r, r3_op3r);
}

# 2r
define pcodeop cls;
:cls r2_op1, r2_op2 is rus_op0=0b00100 & rus_op1=0 & r2_op1 & r2_op2 & $(IS_R2R_FMT) {
	r2_op1 = cls(r2_op2);
}

