# Class-9 Load Memory: Rf=#U6x
LdAddrRsAssignxC9: "("^rf5^"="^Uimm32_0811_0506x^")" is rf5 & rf5_ & Uimm32_0811_0506x {
	# TODO: Need to verify behavior !!
	rf5_ = Uimm32_0811_0506x;
	export Uimm32_0811_0506x;
 <<COMMIT>>
