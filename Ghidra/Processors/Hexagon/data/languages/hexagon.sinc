:neg":sat" Rd5,rs5 EndPacket	is iclass=0x8 & op2127=0x64 & op0513=0x06 & Rd5 & rs5 & $(END_PACKET)
{
	tmp:8 = -sext(rs5);
	Rd5 = saturate32(tmp);
	sat:1 = sborrow(0:4, rs5);
	build EndPacket;
 <<COMMIT>>
    $(OVF) = $(OVF) | sat;
}

