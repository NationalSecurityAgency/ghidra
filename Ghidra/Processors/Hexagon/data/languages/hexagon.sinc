# Class-15 (RIGHT) Store Rs-Relative Memory (Rs16+#u4:2)
StMemRsRelC15Rw: "("^rs4r^")"	is rs4r & i0003=0 {
	ptr:4 = rs4r;
	export *[ram]:4 ptr;
