#
# Non-extended Immediates with shift factor
#
Uimm8_0408_shift3: "#"^val		is i0408 [ val = i0408 << 3; ] { export *[const]:1 val; }
Uimm8_0409_shift2: "#"^val		is i0409  [ val = i0409 << 2; ] { export *[const]:1 val; } 
