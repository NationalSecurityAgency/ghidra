:combine^PuCond0506_N13_S07 rdd5,rs5,rt5 EndPacket  is iclass=15 & op2127=0x68 & PuCond0506_N13_S07 & rs5 & rt5 & rdd5 & rdd5h & rd5 & $(END_PACKET) {
