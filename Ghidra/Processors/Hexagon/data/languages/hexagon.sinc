:assign^PuCond0506_N13_S07 rdd5,rtt5 EndPacket  is iclass=15 & op2127=0x68 & op16=1 & op8=0 & op0912=op1720 & PuCond0506_N13_S07 & rtt5 & rdd5 & $(END_PACKET) {
	tmp:8 = rtt5;
	build PuCond0506_N13_S07;
  	build EndPacket;
