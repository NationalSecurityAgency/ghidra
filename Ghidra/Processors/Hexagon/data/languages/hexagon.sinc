	ptr:4 = SP + offs;
	export *[ram]:8 ptr;
}


# Left Rs-Relative Memory (Rs16+#u4:2)
MemRsRelU4Lw: "("^rs4l^")"	is rs4l & i2427=0 {
	ptr:4 = rs4l;
	export *[ram]:4 ptr;
}
MemRsRelU4Lw: "("^rs4l^"+#"^offs^")"	is rs4l & i2427 [ offs = i2427 << 2; ] {
	ptr:4 = rs4l + offs;
	export *[ram]:4 ptr;
}

