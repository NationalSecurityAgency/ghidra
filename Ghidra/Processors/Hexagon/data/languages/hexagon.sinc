LdMemRsAssignxC9h: LdAddrRsAssignxC9	is LdAddrRsAssignxC9 { export *[ram]:2 LdAddrRsAssignxC9; }
LdMemRsAssignxC9b: LdAddrRsAssignxC9	is LdAddrRsAssignxC9 { export *[ram]:1 LdAddrRsAssignxC9; }

# Class-9 Load Memory: #u6x
